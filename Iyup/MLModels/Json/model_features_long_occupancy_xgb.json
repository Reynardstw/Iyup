{
  "model_kind": "xgboost.XGBRegressor",
  "model_file": "model_long_occupancy_xgb.joblib",
  "coreml_file": "ModelLongOccupancy.mlmodel",
  "target": "occupancy",
  "features_ordered": [
    "spot_num",
    "hour",
    "day_of_week",
    "is_weekend",
    "is_holiday",
    "shadow_status",
    "sun_altitude",
    "cloud_forecast",
    "lead_days"
  ],
  "spot_mapping": {
    "Spot_A": 0,
    "Spot_B": 1,
    "Spot_C": 2,
    "Spot_D": 3,
    "Spot_E": 4,
    "Spot_F": 5
  },
  "notes": "spot_id string harus dikonversi ke spot_num memakai spot_mapping sebelum inference."
}